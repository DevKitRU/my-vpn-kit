{
  "log": { "level": "warn", "timestamp": true },
  "dns": {
    "servers": [
      { "tag": "dns-remote", "type": "https", "server": "1.1.1.1", "detour": "vless-out" },
      { "tag": "dns-direct", "type": "udp", "server": "77.88.8.8" }
    ],
    "rules": [
      {
        "domain_suffix": [
          ".ru", ".рф", ".su",
          "stalcraft.net", "mail.ru", "my.games", "my.com",
          "vk.com", "vk.ru", "userapi.com",
          "gaijin.net", "warface.com", "warthunder.com",
          "xsolla.com",
          "steampowered.com", "steamcommunity.com", "steam-chat.com", "steamgames.com", "steamserver.net", "steamstatic.com", "steamcontent.com",
          "sberbank.com", "sber.com", "tinkoff.com", "alfabank.com"
        ],
        "server": "dns-direct"
      }
    ],
    "final": "dns-remote",
    "strategy": "prefer_ipv4"
  },
  "inbounds": [
    {
      "type": "tun",
      "tag": "tun-in",
      "interface_name": "singbox1",
      "address": ["172.19.0.1/30"],
      "mtu": 9000,
      "auto_route": true,
      "strict_route": false,
      "stack": "system"
    },
    {
      "type": "mixed",
      "tag": "mixed-in",
      "listen": "127.0.0.1",
      "listen_port": 1080
    }
  ],
  "outbounds": [
    {
      "type": "vless",
      "tag": "vless-out",
      "server": "{{SERVER}}",
      "server_port": {{SERVER_PORT}},
      "uuid": "{{UUID}}",
      "flow": "{{FLOW}}",
      "tls": {
        "enabled": true,
        "server_name": "{{SNI}}",
        "utls": { "enabled": true, "fingerprint": "{{FINGERPRINT}}" },
        "reality": {
          "enabled": true,
          "public_key": "{{PUBLIC_KEY}}",
          "short_id": "{{SHORT_ID}}"
        }
      }
    },
    { "type": "direct", "tag": "direct" }
  ],
  "route": {
    "rules": [
      { "action": "sniff" },
      { "protocol": "dns", "action": "hijack-dns" },
      { "ip_is_private": true, "action": "route", "outbound": "direct" },
      {
        "rule_set": ["geoip-ru"],
        "action": "route",
        "outbound": "direct"
      },
      {
        "domain_suffix": [
          ".ru", ".рф", ".su",
          "stalcraft.net", "mail.ru", "my.games", "my.com",
          "vk.com", "vk.ru", "userapi.com", "vk-cdn.net", "vkuseraudio.net", "vkuservideo.net",
          "gaijin.net", "warface.com", "warthunder.com",
          "xsolla.com", "xsollagames.com",
          "steampowered.com", "steamcommunity.com", "steam-chat.com", "steamgames.com", "steamserver.net", "steamstatic.com", "steamcontent.com",
          "yandex.com", "yandex.net", "yastatic.net",
          "sberbank.com", "sber.com", "tinkoff.com", "alfabank.com",
          "ozon.com", "wildberries.com", "avito.com", "avito.st",
          "2gis.com", "rbc.ru", "kinopoisk.ru", "ivi.ru",
          "gosuslugi.ru", "nalog.ru", "nalog.gov.ru"
        ],
        "action": "route",
        "outbound": "direct"
      }
    ],
    "rule_set": [
      {
        "tag": "geoip-ru",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geoip/rule-set/geoip-ru.srs",
        "download_detour": "direct",
        "update_interval": "7d"
      }
    ],
    "auto_detect_interface": true,
    "default_domain_resolver": "dns-direct",
    "final": "vless-out"
  }
}
